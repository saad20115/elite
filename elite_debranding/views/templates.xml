<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Override web layout: set title to Elite Tech -->
    <template id="layout_debranding" inherit_id="web.layout">
        <xpath expr="//title" position="replace">
            <title t-esc="title or 'Elite Tech'"/>
        </xpath>
    </template>

</odoo>
